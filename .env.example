# Copy this file to .env for local development.
# These defaults are for local use only.

# Application
ENVIRONMENT=development
DEBUG=true
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bijmantra_user
POSTGRES_PASSWORD=dev_password_123
POSTGRES_DB=bijmantra_db

# Optional infrastructure
REDIS_HOST=localhost
REDIS_PORT=6379
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MEILISEARCH_HOST=http://localhost:7700

# Local credentials
SECRET_KEY=
ADMIN_PASSWORD=Admin123!
DEMO_PASSWORD=Demo123!

# Optional Being Bijmantra sidecar
BEINGBIJMANTRA_SURREAL_PORT=8083

# Optional Mem0 platform integration
# Set MEM0_ENABLED=true only when you want BijMantra to expose Mem0 as an active optional adapter.
MEM0_ENABLED=false
MEM0_API_KEY=
MEM0_HOST=https://api.mem0.ai
# Leave both blank unless you want explicit project scoping.
MEM0_ORG_ID=
MEM0_PROJECT_ID=

# Optional hidden developer-control-plane headless completion assist
# When BIJMANTRA_DEVELOPER_CONTROL_PLANE_AUTH_TOKEN is set, `make autonomy-cycle`
# and `make update-state` will also stage the derived completion-assist artifact.
# This token is a normal superuser bearer token from /api/auth/login.
# Refresh it locally with: make control-plane-auth-token
BIJMANTRA_DEVELOPER_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8000
BIJMANTRA_DEVELOPER_CONTROL_PLANE_AUTH_TOKEN=