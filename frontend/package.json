{
  "name": "bijmantra-frontend",
  "version": "1.0.0-beta.1",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "build:typecheck": "tsgo --noEmit && vite build",
    "build:typecheck:tsc": "tsc --noEmit && vite build",
    "check:reevu-canonical": "bun ./scripts/check-reevu-canonical.mjs",
    "test:reevu-canonical-guard": "bun test ./scripts/check-reevu-canonical.test.mjs",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "e2e": "cd e2e && bun run test",
    "e2e:ui": "cd e2e && bun run test:ui",
    "e2e:smoke": "cd e2e && bun run test:smoke",
    "e2e:headed": "cd e2e && bun run test:headed",
    "e2e:install": "cd e2e && bun install && bunx playwright install",
    "e2e:bun": "bun run e2e",
    "e2e:ui:bun": "bun run e2e:ui",
    "e2e:smoke:bun": "bun run e2e:smoke",
    "e2e:headed:bun": "bun run e2e:headed",
    "e2e:install:bun": "bun run e2e:install"
  },
